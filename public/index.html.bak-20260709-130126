<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#000510">
    <title>J.A.R.V.I.S.</title>
    <link rel="manifest" href="manifest.json">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><circle cx='50' cy='50' r='45' fill='none' stroke='%2300D4FF' stroke-width='3'/><circle cx='50' cy='50' r='25' fill='%2300D4FF' opacity='0.3'/><circle cx='50' cy='50' r='10' fill='%2300D4FF'/></svg>">
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div id="app">
        <!-- Login Screen -->
        <div id="login-screen" class="screen login-screen">
            <div class="hologram-container">
                <div class="jarvis-ring ring-1"></div>
                <div class="jarvis-ring ring-2"></div>
                <div class="jarvis-ring ring-3"></div>
                <div class="center-core"></div>
            </div>
            
            <div class="login-header">
                <h1 class="jarvis-title">
                    <span class="letter">J</span><span class="letter">.</span><span class="letter">A</span><span class="letter">.</span><span class="letter">R</span><span class="letter">.</span><span class="letter">V</span><span class="letter">.</span><span class="letter">I</span><span class="letter">.</span><span class="letter">S</span><span class="letter">.</span>
                </h1>
                <p class="subtitle">Just A Rather Very Intelligent System</p>
            </div>
            
            <div class="user-selection">
                <p class="scan-line">Bitte identifizieren Sie sich...</p>
                <div class="user-cards">
                    <button class="user-card" data-user="mike">
                        <div class="user-avatar">
                            <div class="avatar-ring"></div>
                            <span class="avatar-initial">M</span>
                        </div>
                        <span class="user-name">Mike</span>
                        <span class="user-role">Administrator</span>
                        <div class="card-glow"></div>
                    </button>
                    <button class="user-card" data-user="tanja">
                        <div class="user-avatar">
                            <div class="avatar-ring"></div>
                            <span class="avatar-initial">T</span>
                        </div>
                        <span class="user-name">Tanja</span>
                        <span class="user-role">Benutzer</span>
                        <div class="card-glow"></div>
                    </button>
                </div>
            </div>
            
            <!-- Password Panel for Mike -->
            <div class="password-panel" id="passwordPanel" style="display: none;">
                <div class="password-form">
                    <div class="password-header">
                        <div class="user-avatar-small">
                            <span class="avatar-initial">M</span>
                        </div>
                        <span class="password-title">Sicherheitsauthentifizierung</span>
                    </div>
                    <div class="input-group password-group">
                        <label class="hud-label">Passwort eingeben</label>
                        <input type="password" id="passwordInput" class="hud-input password-input" placeholder="••••••••" autocomplete="off">
                    </div>
                    <div class="password-actions">
                        <button class="hud-button secondary" id="cancelLogin">Abbrechen</button>
                        <button class="hud-button primary" id="submitPassword">Authentifizieren</button>
                    </div>
                    <div class="password-error" id="passwordError" style="display: none;">
                        <span class="error-icon">⚠</span>
                        <span class="error-text">Falsches Passwort. Zugriff verweigert.</span>
                    </div>
                </div>
            </div>
            
            <div class="system-status">
                <div class="status-indicator online"></div>
                <span class="status-text">System Online</span>
                <span class="version-display" id="versionDisplay"></span>
            </div>
            
            <button class="settings-toggle" id="showSettings">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="3"></circle>
                    <path d="M12 1v6m0 6v6m4.22-10.22l4.24-4.24M6.34 17.66l-4.24 4.24M23 12h-6m-6 0H1m20.24 4.24l-4.24-4.24M6.34 6.34L2.1 2.1"></path>
                </svg>
                Einstellungen
            </button>
            
            <div class="settings-panel" id="settingsPanel" style="display: none;">
                <div class="input-group">
                    <label class="hud-label">API Präfix</label>
                    <input type="url" id="apiUrl" class="hud-input" value="" placeholder="/api/jarvis/... (leer = Standard)">
                    <small class="input-hint">Leer lassen für Vercel-Proxy.</small>
                </div>
                <button class="hud-button" id="saveSettings">Speichern</button>
            </div>
        </div>
        
        <!-- Main Interface -->
        <div id="main-interface" class="screen dashboard-interface" style="display: none;">
            <!-- Header -->
            <header class="dashboard-header">
                <div class="header-left">
                    <div class="system-logo">
                        <div class="mini-ring"></div>
                        <span>J.A.R.V.I.S.</span>
                    </div>
                    <div class="system-status-badge" id="systemStatusBadge">
                        <span class="status-dot online"></span>
                        <span class="status-label">SYSTEM ONLINE</span>
                    </div>
                </div>
                <div class="header-center">
                    <div class="clock-widget">
                        <span id="systemTime">14:00:00</span>
                        <span id="systemDate" class="system-date">--</span>
                    </div>
                </div>
                <div class="header-right">
                    <span class="user-badge" id="currentUser">M</span>
                    <button class="hud-button icon" id="chatToggle" title="Chat">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                    </button>
                    <button class="hud-button icon" id="dashboardRefresh" title="Aktualisieren">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
                    </button>
                    <button class="logout-btn" id="logoutBtn">×</button>
                </div>
            </header>

            <!-- Dashboard Grid -->
            <main class="dashboard-grid" id="dashboardGrid">
                <!-- Left Sidebar: Navigation / Core Status -->
                <aside class="dashboard-sidebar">
                    <nav class="sidebar-nav">
                        <button class="nav-item active" data-view="overview">
                            <span class="nav-icon">◈</span> Übersicht
                        </button>
                        <button class="nav-item" data-view="climate">
                            <span class="nav-icon">🌡️</span> Klima
                        </button>
                        <button class="nav-item" data-view="security">
                            <span class="nav-icon">📹</span> Überwachung
                        </button>
                        <button class="nav-item" data-view="energy">
                            <span class="nav-icon">⚡</span> Energie
                        </button>
                    </nav>

                    <div class="sidebar-widget core-status">
                        <h3>Kernsystem</h3>
                        <ul class="core-list">
                            <li><span class="core-dot active"></span> Hermes API</li>
                            <li><span class="core-dot active"></span> Home Assistant</li>
                            <li><span class="core-dot" id="ngrokStatusDot"></span> ngrok Tunnel</li>
                            <li><span class="core-dot" id="nasStatusDot"></span> NAS</li>
                        </ul>
                    </div>

                    <div class="sidebar-widget voice-widget">
                        <button class="voice-btn large" id="voiceBtn" title="Sprachbefehl">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path>
                                <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
                                <line x1="12" y1="19" x2="12" y2="23"></line>
                                <line x1="8" y1="23" x2="16" y2="23"></line>
                            </svg>
                        </button>
                        <div class="voice-status" id="voiceStatus">Bereit</div>
                    </div>
                </aside>

                <!-- Center: Core Visualization + Key Metrics -->
                <section class="dashboard-center">
                    <!-- Top Row: Solar & Battery -->
                    <div class="widget-row top-metrics">
                        <div class="hud-widget solar-widget">
                            <div class="widget-header">
                                <span class="widget-icon">☀</span>
                                <span>Solar Ertrag</span>
                                <span class="live-badge">LIVE</span>
                            </div>
                            <div class="widget-body">
                                <div class="metric-large" id="solarPower">0 <span class="unit">W</span></div>
                                <div class="metric-sub" id="solarToday">Heute: 0 kWh</div>
                                <div class="solar-bar"><div class="solar-fill" id="solarFill"></div></div>
                            </div>
                        </div>

                        <div class="hud-widget battery-widget">
                            <div class="widget-header">
                                <span class="widget-icon">🔋</span>
                                <span>Speicher</span>
                            </div>
                            <div class="widget-body">
                                <div class="battery-gauge" id="batteryGauge">
                                    <svg viewBox="0 0 100 100"><circle cx="50" cy="50" r="42" class="gauge-bg"></circle><circle cx="50" cy="50" r="42" class="gauge-fill" id="batteryFill"></circle></svg>
                                    <div class="gauge-value" id="batterySoc">10%</div>
                                </div>
                                <div class="metric-sub" id="batteryFlow">Ruhe</div>
                            </div>
                        </div>

                        <div class="hud-widget consumption-widget">
                            <div class="widget-header">
                                <span class="widget-icon">🏠</span>
                                <span>Haushalt</span>
                            </div>
                            <div class="widget-body">
                                <div class="metric-large" id="housePower">0 <span class="unit">W</span></div>
                                <div class="metric-sub" id="gridStatus">Netzbezug</div>
                                <div class="phase-bars">
                                    <div class="phase-bar"><span>L1</span><div class="bar"><div id="phaseA"></div></div></div>
                                    <div class="phase-bar"><span>L2</span><div class="bar"><div id="phaseB"></div></div></div>
                                    <div class="phase-bar"><span>L3</span><div class="bar"><div id="phaseC"></div></div></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Center Core: AI Orb -->
                    <div class="widget-row core-row">
                        <div class="hud-widget core-orb-widget">
                            <div class="voice-container large">
                                <div class="voice-ring ring-outer" id="voiceRing1"></div>
                                <div class="voice-ring ring-middle" id="voiceRing2"></div>
                                <div class="voice-ring ring-inner" id="voiceRing3"></div>
                                <div class="voice-core" id="voiceCore">
                                    <div class="core-pulse"></div>
                                    <span class="core-label">J.A.R.V.I.S.</span>
                                </div>
                            </div>
                            <div class="orb-status" id="voiceStatusCenter">Bereit</div>
                        </div>

                        <!-- Climate Mini Panel -->
                        <div class="hud-widget climate-widget">
                            <div class="widget-header">
                                <span class="widget-icon">❄</span>
                                <span>Klima Wohnzimmer</span>
                            </div>
                            <div class="widget-body climate-body">
                                <div class="climate-temp" id="climateTemp">--°C</div>
                                <div class="climate-mode" id="climateMode">Aus</div>
                                <div class="climate-controls">
                                    <button class="climate-btn" id="climateMinus">−</button>
                                    <button class="climate-btn power" id="climatePower">⏻</button>
                                    <button class="climate-btn" id="climatePlus">+</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Bottom Row: Environment + Notifications -->
                    <div class="widget-row bottom-metrics">
                        <div class="hud-widget env-widget">
                            <div class="widget-header">
                                <span class="widget-icon">🌡</span>
                                <span>Temperaturen</span>
                            </div>
                            <div class="widget-body env-grid" id="envGrid">
                                <div class="env-item"><span>Garten</span><b id="tempGarten">--°C</b></div>
                                <div class="env-item"><span>Pool</span><b id="tempPool">--°C</b></div>
                                <div class="env-item"><span>Wohnz.</span><b id="tempWohn">--°C</b></div>
                                <div class="env-item"><span>Arbeitsz.</span><b id="tempArbeit">--°C</b></div>
                            </div>
                        </div>

                        <div class="hud-widget alerts-widget">
                            <div class="widget-header">
                                <span class="widget-icon">📡</span>
                                <span>Meldungen</span>
                            </div>
                            <div class="widget-body alerts-list" id="alertsList">
                                <div class="alert-item info"><span class="alert-dot"></span>Keine neuen Meldungen</div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Right Sidebar: Cameras + Quick Commands -->
                <aside class="dashboard-rightbar">
                    <div class="hud-widget camera-widget">
                        <div class="widget-header">
                            <span class="widget-icon">📹</span>
                            <span>Kamera</span>
                            <select id="cameraSelect" class="camera-select">
                                <option value="">Auswählen...</option>
                                <option value="front_door">Haustür</option>
                                <option value="back_door">Hintere Tür</option>
                                <option value="einfahrt">Einfahrt</option>
                                <option value="doorbird">Doorbird</option>
                            </select>
                        </div>
                        <div class="camera-feed" id="cameraFeed">
                            <div class="camera-placeholder">Kamera wählen</div>
                        </div>
                    </div>

                    <div class="hud-widget commands-widget">
                        <div class="widget-header">
                            <span class="widget-icon">⚡</span>
                            <span>Schnellbefehle</span>
                        </div>
                        <div class="commands-grid">
                            <button class="cmd-btn" data-command="Licht Wohnzimmer an" data-entity="light.lampe1" data-service="light.turn_on">💡 Wohnzi.</button>
                            <button class="cmd-btn" data-command="Licht Wohnzimmer aus" data-entity="light.lampe1" data-service="light.turn_off">🌑 Dunkel</button>
                            <button class="cmd-btn" data-command="Brunnen an" data-entity="switch.brunnen_garten" data-service="switch.turn_on">⛲ Brunnen</button>
                            <button class="cmd-btn" data-command="Pool an" data-entity="switch.pool_warmepumpe" data-service="switch.turn_on">🏊 Pool</button>
                            <button class="cmd-btn" data-command="Klima Bad an" data-entity="switch.test" data-service="switch.turn_on">🌀 Bad</button>
                            <button class="cmd-btn" data-command="Klima Wohnzimmer an" data-entity="climate.split_klimaanlage" data-service="climate.set_hvac_mode" data-value="cool">❄ Klima</button>
                        </div>
                    </div>

                    <div class="hud-widget chat-widget mini-chat" id="miniChatWidget">
                        <div class="widget-header">
                            <span class="widget-icon">💬</span>
                            <span>Letzte Unterhaltung</span>
                        </div>
                        <div class="chat-messages" id="chatContainer">
                            <div class="message-bubble jarvis compact">
                                <div class="message-content"><p>Guten Tag, Sir. Ich bin bereit.</p></div>
                            </div>
                        </div>
                    </div>
                </aside>
            </main>

            <!-- Dashboard Footer -->
            <footer class="dashboard-footer">
                <div class="footer-left">
                    <span class="connection-status online">● Verbindung aktiv</span>
                    <span id="haEntityCount">HA: -- Entitäten</span>
                </div>
                <div class="footer-center">
                    <span class="version" id="footerVersion">v1.0.0</span>
                </div>
                <div class="footer-right">
                    <button class="hud-button small" id="cameraBtn">📷 Analyse</button>
                    <div class="input-pill">
                        <input type="text" id="textInput" placeholder="Befehl oder Frage...">
                        <button id="sendBtn">➤</button>
                    </div>
                </div>
            </footer>

            <!-- Chat Overlay (full) -->
            <div class="chat-overlay" id="chatOverlay" style="display: none;">
                <div class="chat-panel">
                    <div class="chat-panel-header">
                        <span>J.A.R.V.I.S. Dialog</span>
                        <button class="close-panel" id="closeChat">×</button>
                    </div>
                    <div class="chat-panel-body" id="chatPanelBody"></div>
                    <div class="chat-panel-footer">
                        <input type="text" id="chatPanelInput" placeholder="Geben Sie einen Befehl ein...">
                        <button id="chatPanelSend">➤</button>
                    </div>
                </div>
            </div>

            <!-- Camera Overlay -->
            <div class="camera-overlay" id="cameraOverlay" style="display: none;">
                <div class="camera-frame">
                    <video id="cameraVideo" autoplay playsinline></video>
                    <canvas id="cameraCanvas" style="display: none;"></canvas>
                    <div class="camera-controls">
                        <button class="hud-button secondary" id="cameraCancel">Abbrechen</button>
                        <button class="hud-button primary" id="cameraCapture">Aufnehmen</button>
                    </div>
                    <div class="camera-hint">Halten Sie das Objekt ruhig. Das Bild wird zur Analyse an J.A.R.V.I.S. gesendet.</div>
                </div>
            </div>

            <!-- Scan Line Effect -->
            <div class="scan-overlay"></div>
        </div>
    </div>
    
    <script src="app.js"></script>
</body>
</html>
